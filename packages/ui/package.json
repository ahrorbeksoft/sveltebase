{
  "name": "@svelte-essentials/ui",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "scripts": {
    "build": "svelte-package --input ./src --output ./dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "publint --strict --pack npm",
    "clean": "rm -rf dist"
  }
}
