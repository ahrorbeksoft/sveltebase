{
  "name": "@svelte-essentials/instant",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@instantdb/svelte": "^0.22.165",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@instantdb/svelte": "^0.22.165"
  },
  "scripts": {
    "build": "svelte-package --input ./src --output ./dist",
    "check": "tsc --project tsconfig.json --noEmit",
    "lint": "bun run build && publint --strict --pack npm",
    "clean": "rm -rf dist"
  }
}
