{
  "name": "@svelte-essentials/all",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    }
  },
  "dependencies": {
    "@svelte-essentials/ui": "0.1.0",
    "@svelte-essentials/utils": "0.1.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts src/ui.ts src/utils.ts --format esm --dts --clean",
    "check": "tsc --project tsconfig.json --noEmit",
    "lint": "publint --strict --pack npm",
    "clean": "rm -rf dist"
  }
}
