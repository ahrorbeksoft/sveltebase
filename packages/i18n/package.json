{
  "name": "@svelte-essentials/i18n",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@svelte-essentials/state": "0.1.0",
    "date-fns": "^4.1.0",
    "use-intl": "^4.4.0",
    "zod": "^4.1.11"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "check": "tsc --project tsconfig.json --noEmit",
    "lint": "bun run build && publint --strict --pack npm",
    "clean": "rm -rf dist"
  }
}
